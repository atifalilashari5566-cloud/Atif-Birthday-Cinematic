/* ==========================================
   HAPPY BIRTHDAY ATIF ❤️
   PREMIUM CINEMATIC THEME
========================================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html,
body{
    width:100%;
    height:100%;
    overflow:hidden;
    font-family:'Poppins',sans-serif;
    background:#020817;
    color:#ffffff;
}

body{
    background:
    linear-gradient(180deg,#020817 0%,#071b3a 45%,#0b2e63 100%);
}

/* =========================
   BACKGROUND LAYERS
========================= */

#stars,
#clouds,
#hearts,
#flowers,
#fireworks,
#confetti{
    position:fixed;
    inset:0;
    pointer-events:none;
    overflow:hidden;
}

#moon{
    position:fixed;
    top:60px;
    right:70px;
    width:120px;
    height:120px;
    border-radius:50%;
    background:white;
    box-shadow:
        0 0 40px #fff,
        0 0 90px #7cc8ff;
}

/* =========================
   SCENES
========================= */

.scene{
    position:absolute;
    inset:0;
    display:flex;
    justify-content:center;
    align-items:center;
    opacity:0;
    visibility:hidden;
    transition:1s;
}

.scene.active{
    opacity:1;
    visibility:visible;
}

/* =========================
   GLASS CARD
========================= */

.glass{

    width:90%;
    max-width:760px;

    padding:45px;

    border-radius:25px;

    text-align:center;

    background:rgba(255,255,255,.08);

    backdrop-filter:blur(18px);

    border:1px solid rgba(255,255,255,.15);

    box-shadow:0 0 35px rgba(0,150,255,.25);

}

h1{

    font-size:54px;

    margin-bottom:18px;

}

h2{

    font-size:34px;

    color:#FFD54F;

    margin-bottom:20px;

}

.date{

    font-size:26px;

    color:#8fd7ff;

    margin-bottom:25px;

}

p{

    font-size:20px;

    line-height:1.8;

}

button{

    margin-top:35px;

    padding:16px 40px;

    border:none;

    border-radius:50px;

    background:#1E88E5;

    color:white;

    font-size:20px;

    cursor:pointer;

    transition:.35s;

}

button:hover{

    transform:scale(1.08);

}
